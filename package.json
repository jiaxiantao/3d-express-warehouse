{
  "name": "3d-express-warehouse",
  "version": "1.0.0",
  "description": "3D warehouse visualization with slot status mapping, inventory display, and one-click management. Next.js + React Three Fiber.",
  "license": "MIT",
  "private": false,
  "author": "jiaxiantao (https://github.com/jiaxiantao)",
  "repository": {
    "type": "git",
    "url": "https://github.com/jiaxiantao/3d-express-warehouse.git"
  },
  "bugs": {
    "url": "https://github.com/jiaxiantao/3d-express-warehouse/issues"
  },
  "homepage": "https://jiaxiantao.github.io/3d-express-warehouse/",
  "keywords": [
    "threejs",
    "react-three-fiber",
    "3d",
    "warehouse",
    "wms",
    "inventory",
    "logistics",
    "nextjs",
    "webgl",
    "visualization"
  ],
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=2048' next dev --webpack -p 3100",
    "dev:stop": "node scripts/dev-stop.mjs",
    "dev:fresh": "node scripts/dev-stop.mjs && NODE_OPTIONS='--max-old-space-size=2048' next dev --webpack -p 3100",
    "build": "next build",
    "build:pages": "GITHUB_PAGES=true NEXT_PUBLIC_BASE_PATH=/3d-express-warehouse NEXT_PUBLIC_SITE_URL=https://jiaxiantao.github.io/3d-express-warehouse next build && node scripts/export-to-docs.mjs",
    "start": "PORT=3100 node .next/standalone/server.js",
    "start:ci": "next start -p 3100",
    "lint": "eslint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-three/fiber": "^9.6.1",
    "clsx": "^2.1.1",
    "html5-qrcode": "^2.3.8",
    "next": "16.2.6",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "three": "^0.181.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.181.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "packageManager": "pnpm@9.15.9+sha512.68046141893c66fad01c079231128e9afb89ef87e2691d69e4d40eee228988295fd4682181bae55b58418c3a253bde65a505ec7c5f9403ece5cc3cd37dcf2531"
}
